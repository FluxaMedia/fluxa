<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/calendar_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05070B"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/calendar_widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:fontFamily="sans"
        android:maxLines="1"
        android:textColor="#FFFFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/calendar_widget_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:background="#12FFFFFF"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="3"
        android:padding="12dp"
        android:textColor="#B8FFFFFF"
        android:textSize="12sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/calendar_widget_row_1"
        style="@style/CalendarWidgetRow.Highlighted">

        <TextView
            android:id="@+id/calendar_widget_row_1_date"
            style="@style/CalendarWidgetRowDate.Highlighted" />

        <LinearLayout style="@style/CalendarWidgetRowBody">
            <TextView
                android:id="@+id/calendar_widget_row_1_title"
                style="@style/CalendarWidgetRowTitle.Highlighted" />

            <TextView
                android:id="@+id/calendar_widget_row_1_subtitle"
                style="@style/CalendarWidgetRowSubtitle" />
        </LinearLayout>

        <TextView
            android:id="@+id/calendar_widget_row_1_episode"
            style="@style/CalendarWidgetRowEpisode" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/calendar_widget_row_2"
        style="@style/CalendarWidgetRow">

        <TextView
            android:id="@+id/calendar_widget_row_2_date"
            style="@style/CalendarWidgetRowDate" />

        <LinearLayout style="@style/CalendarWidgetRowBody">
            <TextView
                android:id="@+id/calendar_widget_row_2_title"
                style="@style/CalendarWidgetRowTitle" />

            <TextView
                android:id="@+id/calendar_widget_row_2_subtitle"
                style="@style/CalendarWidgetRowSubtitle" />
        </LinearLayout>

        <TextView
            android:id="@+id/calendar_widget_row_2_episode"
            style="@style/CalendarWidgetRowEpisode" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/calendar_widget_row_3"
        style="@style/CalendarWidgetRow">

        <TextView
            android:id="@+id/calendar_widget_row_3_date"
            style="@style/CalendarWidgetRowDate" />

        <LinearLayout style="@style/CalendarWidgetRowBody">
            <TextView
                android:id="@+id/calendar_widget_row_3_title"
                style="@style/CalendarWidgetRowTitle" />

            <TextView
                android:id="@+id/calendar_widget_row_3_subtitle"
                style="@style/CalendarWidgetRowSubtitle" />
        </LinearLayout>

        <TextView
            android:id="@+id/calendar_widget_row_3_episode"
            style="@style/CalendarWidgetRowEpisode" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/calendar_widget_row_4"
        style="@style/CalendarWidgetRow">

        <TextView
            android:id="@+id/calendar_widget_row_4_date"
            style="@style/CalendarWidgetRowDate" />

        <LinearLayout style="@style/CalendarWidgetRowBody">
            <TextView
                android:id="@+id/calendar_widget_row_4_title"
                style="@style/CalendarWidgetRowTitle" />

            <TextView
                android:id="@+id/calendar_widget_row_4_subtitle"
                style="@style/CalendarWidgetRowSubtitle" />
        </LinearLayout>

        <TextView
            android:id="@+id/calendar_widget_row_4_episode"
            style="@style/CalendarWidgetRowEpisode" />
    </LinearLayout>
</LinearLayout>
